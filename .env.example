# Copy this file to .env in the repo root or to server/.env.
# Never commit your real secrets.

# Shared app URLs
NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:5173

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/resumeroast

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Claude AI
# Keep USE_DEMO_AI=true for local UI testing without using API quota.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_OUTPUT_TOKENS=3200
USE_DEMO_AI=true
RESUME_MAX_CHARS=12000
RESUME_MAX_BYTES=5242880
FREE_ANALYSIS_LIMIT=1
PRO_DAILY_ANALYSIS_LIMIT=10

# AWS S3 resume storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Stripe subscriptions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_SUCCESS_URL=http://localhost:5173/dashboard?checkout=success
STRIPE_CANCEL_URL=http://localhost:5173/pricing?checkout=cancelled

# SendGrid receipt email, optional for Stripe receipts
SENDGRID_API_KEY=
FROM_EMAIL=no-reply@resumeroast.local

# Frontend
VITE_API_URL=http://localhost:5001/api
